services:
  # The PHP-FPM Engine
  statamic-app:
    image: serversideup/php:8.4-fpm
    container_name: statamic_app
    restart: always
    environment:
      - PUID=1000  # Matches your Ubuntu User
      - PGID=1000
    volumes:
      - ./site:/var/www/html:U
    networks:
      - web-stack

  # The Local Nginx (Handles static assets & passes PHP to FPM)
statamic-web:
    image: nginx:alpine
    container_name: statamic_web
    restart: always
    volumes:
      - ./site:/var/www/html:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - statamic-app
    networks:
      - web-stack
networks:
  web-stack:
    external: true
